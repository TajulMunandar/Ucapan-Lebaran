# ==============================================
# Supabase Configuration (Required)
# ==============================================
# Get these from your Supabase project settings
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Service role key (for backend API) - KEEP SECRET!
# Get this from Supabase project settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ==============================================
# DANA Payment Gateway Configuration (Required)
# ==============================================
# Sandbox Base URL: https://api.sandbox.dana.id
# Production Base URL: https://api.dana.id
DANA_API_BASE_URL=https://api-sandbox.dana.id

# Get these from DANA Merchant Dashboard
DANA_MERCHANT_ID=216620030020046547602
DANA_CLIENT_ID=2026032211195206312828
DANA_CLIENT_SECRET=687b65d451241f086eeb76f6aba6f0eb918da3619664d4d0ab73479cfcb56f8c

# ==============================================
# Site Configuration (Required)
# ==============================================
# Your deployed site URL (for payment callbacks)
SITE_URL=https://your-site.vercel.app

# ==============================================
# Midtrans Configuration (Optional - Legacy)
# ==============================================
# Get these from https://dashboard.midtrans.com
MIDTRANS_SERVER_KEY=your-midtrans-server-key
MIDTRANS_CLIENT_KEY=your-midtrans-client-key
MIDTRANS_IS_PRODUCTION=false

# ==============================================
# Resend Configuration (Optional - for emails)
# ==============================================
# Get API key from https://resend.com
RESEND_API_KEY=your-resend-api-key
